# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

DEBUG=False

# Comma-separated — include your Railway domain and any custom domain
ALLOWED_HOSTS=yourapp.up.railway.app,yourdomain.com

# Comma-separated with https://
CSRF_TRUSTED_ORIGINS=https://yourapp.up.railway.app,https://yourdomain.com

# Resend SMTP — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

DEFAULT_FROM_EMAIL=noreply@yourdomain.com
